# =============================================================================
# PAVILION — Production-Ready .gitignore
# React Vite (client/) + Node/Express (server/)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. ENVIRONMENT & SECRETS
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# SSL / Private-key secrets
*.pem
*.key
*.crt
*.p12
*.pfx

# client-side env overrides
client/.env
client/.env.local
client/.env.development
client/.env.development.local
client/.env.test
client/.env.test.local
client/.env.production
client/.env.production.local

# server-side env overrides
server/.env
server/.env.local
server/.env.development
server/.env.development.local
server/.env.test
server/.env.test.local
server/.env.production
server/.env.production.local

# -----------------------------------------------------------------------------
# 2. DEPENDENCY FOLDERS
# -----------------------------------------------------------------------------
node_modules/
client/node_modules/
server/node_modules/

# Package manager lock files (keep ONE; ignore the rest)
# Uncomment the lock file your team does NOT use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# 3. PRODUCTION BUILD OUTPUTS
# -----------------------------------------------------------------------------
dist/
build/
out/
.output/
client/dist/
client/build/
client/out/
server/dist/
server/build/

# Vite-specific cache
.vite/
client/.vite/

# -----------------------------------------------------------------------------
# 4. OS-SPECIFIC SYSTEM FILES
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# 5. IDE & EDITOR CONFIGURATIONS
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/

# -----------------------------------------------------------------------------
# 6. LOGS
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
server/logs/
client/logs/

# -----------------------------------------------------------------------------
# 7. TEST COVERAGE REPORTS
# -----------------------------------------------------------------------------
coverage/
client/coverage/
server/coverage/
.nyc_output/
lcov.info
*.lcov

# Vitest / Jest
test-results/
playwright-report/
.jest-cache/

# -----------------------------------------------------------------------------
# 8. RUNTIME & PROCESS FILES
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.node_repl_history
.npm
.eslintcache
.stylelintcache
.parcel-cache

# -----------------------------------------------------------------------------
# 9. OPTIONAL / TOOLING
# -----------------------------------------------------------------------------
# Serverless Framework
.serverless/

# Terraform
*.tfstate
*.tfstate.*
.terraform/

# Docker (keep Dockerfiles tracked, ignore local overrides)
docker-compose.override.yml

# Storybook build
storybook-static/

# Turbo / monorepo cache
.turbo/
.cache/
