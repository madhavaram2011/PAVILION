# ══════════════════════════════════════════════════════════════════
# Pavilion API — Environment Variables
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/pavilion
# Atlas:   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pavilion?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/pavilion

# ── JWT Authentication ────────────────────────────────────────────
JWT_SECRET=pavilion_super_secret_key_change_me_in_production
JWT_EXPIRES_IN=90d

# ── Google Geocoding API (optional — fallback coords work without it)
# GOOGLE_API_KEY=your_google_api_key_here

# ── Cloudinary (optional — for image uploads in the future)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ── Email / SMTP (optional — for booking confirmations in the future)
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=587
# EMAIL_USERNAME=your_email_username
# EMAIL_PASSWORD=your_email_password
# EMAIL_FROM=noreply@pavilion.dev

# ── Rate Limiting (optional)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=900000
