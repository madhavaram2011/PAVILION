# ══════════════════════════════════════════════════════════════════
# PAVILION — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/pavilion
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pavilion
MONGODB_URI=mongodb://localhost:27017/pavilion

# ── JWT — Access Token (short-lived) ───────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=15m

# ── JWT — Refresh Token (long-lived, httpOnly cookie) ──────────────
JWT_REFRESH_SECRET=replace_with_a_different_strong_random_secret
JWT_REFRESH_EXPIRES=7d

# ── CORS ───────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Google Maps API (optional) ─────────────────────────────────────
# GOOGLE_API_KEY=your_google_api_key_here
